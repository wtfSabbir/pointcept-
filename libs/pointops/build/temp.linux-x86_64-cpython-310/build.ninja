ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -pthread -Wno-unused-result -Wsign-compare -Wunreachable-code -DNDEBUG -g -fwrapv -O3 -Wall -O3 -fPIC -fPIC -I/mnt/d/PointCloudsFiles/Pointcept/.venv-pointcept/lib/python3.10/site-packages/torch/include -I/mnt/d/PointCloudsFiles/Pointcept/.venv-pointcept/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/mnt/d/PointCloudsFiles/Pointcept/.venv-pointcept/lib/python3.10/site-packages/torch/include/TH -I/mnt/d/PointCloudsFiles/Pointcept/.venv-pointcept/lib/python3.10/site-packages/torch/include/THC -I/usr/local/cuda/include -I/mnt/d/PointCloudsFiles/Pointcept/.venv-pointcept/include -I/home/sabbir/.local/share/uv/python/cpython-3.10.19-linux-x86_64-gnu/include/python3.10 -c
post_cflags = -g -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -I/mnt/d/PointCloudsFiles/Pointcept/.venv-pointcept/lib/python3.10/site-packages/torch/include -I/mnt/d/PointCloudsFiles/Pointcept/.venv-pointcept/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/mnt/d/PointCloudsFiles/Pointcept/.venv-pointcept/lib/python3.10/site-packages/torch/include/TH -I/mnt/d/PointCloudsFiles/Pointcept/.venv-pointcept/lib/python3.10/site-packages/torch/include/THC -I/usr/local/cuda/include -I/mnt/d/PointCloudsFiles/Pointcept/.venv-pointcept/include -I/home/sabbir/.local/share/uv/python/cpython-3.10.19-linux-x86_64-gnu/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O2 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_75,code=compute_75 -gencode=arch=compute_75,code=sm_75 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





